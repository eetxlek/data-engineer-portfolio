cat > .gitignore << 'EOF'
# Entorno virtual
venv/
__pycache__/
*.pyc

# Datos generados
data/*.json
data/*.jsonl
!data/.gitkeep

# Lake (Parquet files - pueden ser grandes)
data/lake/

# Variables de entorno
.env

# IDE
.vscode/
.idea/

# OS
.DS_Store

# Logs
*.log
spark-warehouse/
metastore_db/
derby.log
EOF